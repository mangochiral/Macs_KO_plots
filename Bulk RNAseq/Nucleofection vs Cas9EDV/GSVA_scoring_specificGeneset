gsva_results_f<-gsva_results_f[,grep("D7", colnames(gsva_results_f))]
colnames(gsva_results_f)<-gsub("X.", "", colnames(gsva_results_f))
colnames(gsva_results_f)<-gsub(".d", "_", colnames(gsva_results_f))
colnames(gsva_results_f)<-gsub(".D7", "", colnames(gsva_results_f))
colnames(gsva_results_f)<-gsub("2NTD", "NTD", colnames(gsva_results_f))
colnames(gsva_results_f)<-gsub("3Nuc", "Nuc", colnames(gsva_results_f))
colnames(gsva_results_f)<-gsub("4EDV", "EDV", colnames(gsva_results_f))
colnames(gsva_results_f)<-gsub(".AAV", "", colnames(gsva_results_f))

pathway_heatmap <- pheatmap::pheatmap(gsva_results_f,
  show_colnames = TRUE,
  fontsize_row = 10,
  scale="row" # Shrink the pathway labels a tad
)

pdf("GSVA/pathway_heatmap_markergenes_macrophage2.pdf", width=6, height=4)
pathway_heatmap
dev.off()
