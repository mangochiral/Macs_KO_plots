##1. monocyte, nuc vs edv

df1<-read.table("GSEA_output/edv_mo_gsea_result.txt", header=T, stringsAsFactor=F)
df2<-read.table("GSEA_output/nuc_mo_gsea_result.txt", header=T, stringsAsFactor=F)

colnames(df1)[2:7]<-paste0("edv_", colnames(df1)[2:7])
colnames(df2)[2:7]<-paste0("nuc_", colnames(df2)[2:7])

df<-merge(df1, df2, by="pathway")
df<-na.omit(df)
df<-df[grep("HALLMARK", df$pathway),]

target<- ifelse (df$edv_padj < 0.01, 1, ifelse (df$nuc_padj<0.01, 1, 0)) 

df2<-df[target==1,]
dim(df2)
##1065 geneset

library(GO.db)
goterms <- Term(df2$pathway)
#df2<-data.frame(df2, label=goterms)
df2<-data.frame(df2, label=df2$pathway)

target<-unique(df2$label[ abs(df2$edv_NES) > sort(abs(df2$edv_NES), decreasing=T)[5]])
target<-unique(c(target, df2$label[abs(df2$nuc_NES) > sort(abs(df2$nuc_NES), decreasing=T)[5]]))
tmp<-df2[df2$nuc_NES * df2$edv_NES < 0 , ]
if(nrow(tmp)>5){
target<-unique(c(target, tmp$label[abs(tmp$nuc_NES) > sort(abs(tmp$nuc_NES), decreasing=T)[5]]))
target<-unique(c(target, tmp$label[abs(tmp$edv_NES) > sort(abs(tmp$edv_NES), decreasing=T)[5]]))
} else {
target<-unique(c(target, tmp$label))
}

target<-c(target, "HALLMARK_P53_PATHWAY", "HALLMARK_APOPTOSIS")
df2$label[!is.element(df2$label, target)]<-""
df2$label<-gsub("HALLMARK_", "", df2$label)

library(ggplot2)
library(ggrepel)
g<-ggplot(df2, aes(x=edv_NES, y=nuc_NES, label=label))
g<-g +  theme_set(theme_classic(base_family = "Helvetica", base_size=20))
g<-g + geom_point(size=4)
g<-g + geom_vline(xintercept=0)
g<-g + geom_hline(yintercept=0)
g<-g + geom_text_repel(max.overlaps=100, point.size=4)
ggsave(plot=g, "figure/GO_comp_monocyte_nuc_vs_edv.pdf", width=8, height=8)


