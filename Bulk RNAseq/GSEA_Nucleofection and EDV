wd="/oak/stanford/groups/pritch/users/mineto/workstation/250425_Hyuncheol"
setwd(wd)

edv_mo<-read.table("data/NTD_None_D1_monocyte-vs-EDV_AAVS1_D1_monocyte.txt", header=T, stringsAsFactor=F)
nuc_mo<-read.table("data/NTD_None_D1_monocyte-vs-Nuc_AAVS1_D1_monocyte.txt", header=T, stringsAsFactor=F)

edv_mac<-read.table("data/NTD_None_D7_macrophage-vs-EDV_AAVS1_D7_macrophage.txt", header=T, stringsAsFactor=F)
nuc_mac<-read.table("data/NTD_None_D7_macrophage-vs-Nuc_AAVS1_D7_macrophage.txt", header=T, stringsAsFactor=F)


library(msigdbr)
library(fgsea)
library(dplyr)
library(ggplot2)
library(tibble)

##


# 1. Retrieve Hallmark gene sets for Homo sapiens
hallmarks <- msigdbr(species = "Homo sapiens", category = "H") %>%
  select(gs_name, ensembl_gene) %>%
  split(x = .$ensembl_gene, f = .$gs_name)

library(org.Hs.eg.db)

keys<-keys(org.Hs.eg.db,keytype="GOALL")
go_genesets <- AnnotationDbi::select(org.Hs.eg.db, keytype="GOALL", columns="ENSEMBL", keys=keys)

go_selected<-split(
  go_genesets$ENSEMBL, # The genes we want split into pathways
  go_genesets$GOALL # The pathways made as the higher levels of the list
)

allgeneset <-c(hallmarks, go_selected)

##
# 3. Create a ranking using the Wald statistic to avoid ties
# Load necessary libraries
df=edv_mo

library(dplyr)
ranking <- df %>%
  filter(!is.na(log2FoldChange)) %>%
  arrange(desc(abs(stat))) %>%
  filter(!duplicated(gene)) %>%
  arrange(desc(stat)) %>%
  distinct( ensembl_id, .keep_all = TRUE) %>%
  dplyr::select( ensembl_id, stat) %>%
  deframe()

# 4. Run fgsea using the multilevel method
fgseaRes <- fgsea(
  pathways = allgeneset,
  stats    = ranking,
  minSize  = 20,   # minimum gene set size
  maxSize  = 1000   # maximum gene set size
)

res<-as.data.frame(fgseaRes)[,1:7]
write.table(res, "GSEA_output/edv_mo_gsea_result.txt", row.names=F, sep="\t", quote=F)


